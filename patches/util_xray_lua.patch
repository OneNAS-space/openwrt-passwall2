Subject: [PATCH] Set default fragment lengths in util_xray.lua

---
 luci-app-passwall2/luasrc/passwall2/util_xray.lua | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/luci-app-passwall2/luasrc/passwall2/util_xray.lua b/luci-app-passwall2/luasrc/passwall2/util_xray.lua
index 6bb03c23d..dddbc8be2 100644
